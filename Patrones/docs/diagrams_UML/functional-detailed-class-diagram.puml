@startuml
title MES Functional Project - Detailed Class Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam wrapWidth 180
skinparam maxMessageSize 120

top to bottom direction
scale max 1800 width

hide empty members

package "Application Layer" {
  class OrderExecutionRequest {
    +template_key: str
    +order_id: str
    +planned_units: int
    +shift: str
    +protocol: str = "opcua"
  }

  class PatternImplementation {
    +pattern: str
    +objective: str
    +module: str
    +key_classes: str
    +usage_point: str
  }

  class FunctionalMESProject {
    -_controller: MESController
    -_planner: MESProductionPlanner
    -_capacity_service: MESCapacityService
    -_operator_console: MESOperatorConsole
    -_tracking_client: MESProductionClient
    -_report_director: ReportDirector
    -_shift_closer: MESShiftCloser
    -_line_factories: dict[str, ProductionLineFactory]
    -_machine_factories: dict[str, MachineFactory]
    +get_pattern_map(): list[PatternImplementation]
    -_build_dispatcher(machine_type: str, protocol: str): MESScheduler
    +execute_order(request: OrderExecutionRequest): dict[str, Any]
  }
}

package "Singleton" {
  class PlannedOrder {
    +order_id: str
    +production_line: str
    +planned_units: int
    +machine_type: str
    +shift: str
  }

  class MESController <<Singleton>> {
    -_instance: MESController
    -_initialized: bool
    -_planned_orders: dict[str, PlannedOrder]
    -_closed_reports: list[dict[str, Any]]
    -_totals: dict[str, int]
    +reset(): None
    +plan_production(order_id: str, production_line: str, planned_units: int, machine_type: str, shift: str): PlannedOrder
    +register_execution(order_id: str, produced_units: int, downtime_minutes: int): None
    +close_order(order_id: str, final_report: dict[str, Any]): None
    +calculate_oee(): float
    +summary(): dict[str, Any]
  }
}

package "Factory Method" {
  abstract class Machine {
    +start(): str
    +produce(planned_units: int): int
  }

  class CNCMachine {
    +start(): str
    +produce(planned_units: int): int
  }

  class RobotMachine {
    +start(): str
    +produce(planned_units: int): int
  }

  abstract class MachineFactory {
    +create_machine(): Machine
    +start_machine(): str
  }

  class CNCFactory {
    +create_machine(): Machine
  }

  class RobotFactory {
    +create_machine(): Machine
  }
}

package "Abstract Factory" {
  abstract class LineMachine {
    +operate(): str
  }

  abstract class Robot {
    +assist(): str
  }

  class AF_CNCMachine {
    +operate(): str
  }

  class ManualMachine {
    +operate(): str
  }

  class IndustrialRobot {
    +assist(): str
  }

  class HumanOperator {
    +assist(): str
  }

  abstract class ProductionLineFactory {
    +create_machine()
    +create_robot()
  }

  class AutomaticLineFactory {
    +create_machine()
    +create_robot()
  }

  class ManualLineFactory {
    +create_machine()
    +create_robot()
  }
}

package "Builder" {
  class ProductionReport {
    +order_id: str
    +production_line: str
    +shift: str
    +units_planned: int
    +units_produced: int
    +downtime_minutes: int
    +quality_alerts: list[str]
    +operator_notes: str
  }

  abstract class ProductionReportBuilder {
    +reset()
    +set_header(order_id: str, production_line: str, shift: str)
    +set_output(units_planned: int, units_produced: int, downtime_minutes: int)
    +add_quality_alert(alert: str)
    +set_operator_notes(notes: str)
    +build(): ProductionReport
  }

  class StandardProductionReportBuilder {
    -_report: ProductionReport
    +reset()
    +set_header(order_id: str, production_line: str, shift: str)
    +set_output(units_planned: int, units_produced: int, downtime_minutes: int)
    +add_quality_alert(alert: str)
    +set_operator_notes(notes: str)
    +build(): ProductionReport
  }

  class ReportDirector {
    -_builder: ProductionReportBuilder
    +build_standard_shift_report(order_id: str, production_line: str, shift: str, units_planned: int, units_produced: int, downtime_minutes: int, notes: str): ProductionReport
    +build_report_with_alerts(order_id: str, production_line: str, shift: str, units_planned: int, units_produced: int, downtime_minutes: int, notes: str, alerts: list[str]): ProductionReport
  }
}

package "Adapter" {
  abstract class ProductionTrackingService {
    +report_units(order_id: str, production_line: str, units: int): str
  }

  class LegacyMachineGateway {
    +send_production_data(legacy_order_ref: str, legacy_line_code: str, produced_qty: int): str
  }

  class LegacyMachineAdapter {
    -_adaptee: LegacyMachineGateway
    +report_units(order_id: str, production_line: str, units: int): str
  }

  class MESProductionClient {
    -_tracking_service: ProductionTrackingService
    +close_partial_report(order_id: str, production_line: str, units: int): str
  }
}

package "Prototype" {
  abstract class Prototype {
    +clone(): Prototype
  }

  class ProductionOrderTemplate {
    +template_name: str
    +machine_profile: dict[str, Any]
    +quality_checks: list[str]
    +parameters: dict[str, Any]
    +order_id: str
    +planned_units: int
    +shift: str
    +clone(): ProductionOrderTemplate
    +configure_for_order(order_id: str, planned_units: int, shift: str): ProductionOrderTemplate
    +summary(): str
  }

  class TemplateRegistry {
    -_templates: dict[str, ProductionOrderTemplate]
    +register(key: str, template: ProductionOrderTemplate): None
    +create(key: str): ProductionOrderTemplate
  }

  class MESProductionPlanner {
    -_registry: TemplateRegistry
    +prepare_order(template_key: str, order_id: str, planned_units: int, shift: str): ProductionOrderTemplate
  }
}

package "Bridge" {
  abstract class CommunicationChannel {
    +transmit(production_line: str, payload: str): str
  }

  class OPCUAChannel {
    +transmit(production_line: str, payload: str): str
  }

  class ModbusChannel {
    +transmit(production_line: str, payload: str): str
  }

  abstract class WorkOrder {
    -_channel: CommunicationChannel
    +dispatch(order_id: str, production_line: str, units: int): str
  }

  class CNCWorkOrder {
    +dispatch(order_id: str, production_line: str, units: int): str
  }

  class RobotWorkOrder {
    +dispatch(order_id: str, production_line: str, units: int): str
  }

  class MESScheduler {
    -_work_order: WorkOrder
    +release_order(order_id: str, production_line: str, units: int): str
  }
}

package "Decorator" {
  abstract class ReportComponent {
    +build(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }

  class BaseProductionReport {
    +build(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }

  abstract class ReportDecorator {
    -_wrappee: ReportComponent
    +build(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }

  class QualityDecorator {
    +build(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }

  class TraceabilityDecorator {
    +build(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }

  class OEEDecorator {
    +build(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }

  class MESShiftCloser {
    -_report_builder: ReportComponent
    +close_shift(order_id: str, planned_units: int, produced_units: int): dict[str, Any]
  }
}

package "Composite" {
  abstract class ProductionNode {
    +total_planned_units(): int
    +summary(depth: int = 0): str
  }

  class MachineStation {
    +name: str
    +planned_units: int
    +total_planned_units(): int
    +summary(depth: int = 0): str
  }

  class ProductionGroup {
    +name: str
    -_children: list[ProductionNode]
    +add(node: ProductionNode): None
    +remove(node: ProductionNode): None
    +total_planned_units(): int
    +summary(depth: int = 0): str
  }

  class MESCapacityService {
    -_root: ProductionNode
    +calculate_total_units(): int
    +export_structure(): str
  }
}

package "Facade" {
  class OrderValidator {
    +validate(order_id: str, planned_units: int): bool
  }

  class InventoryService {
    +reserve_material(order_id: str, planned_units: int): str
  }

  class MachinePreparationService {
    +prepare_line(production_line: str): str
  }

  class QualityService {
    +load_checklist(order_id: str): str
  }

  class TrackingService {
    +open_batch(order_id: str, production_line: str): str
  }

  class MESProductionFacade {
    -_validator: OrderValidator
    -_inventory: InventoryService
    -_preparation: MachinePreparationService
    -_quality: QualityService
    -_tracking: TrackingService
    +start_order(order_id: str, production_line: str, planned_units: int): dict[str, Any]
  }

  class MESOperatorConsole {
    -_facade: MESProductionFacade
    +run_startup(order_id: str, production_line: str, planned_units: int): dict[str, Any]
  }
}

' Inheritance
Machine <|-- CNCMachine
Machine <|-- RobotMachine
MachineFactory <|-- CNCFactory
MachineFactory <|-- RobotFactory

LineMachine <|-- AF_CNCMachine
LineMachine <|-- ManualMachine
Robot <|-- IndustrialRobot
Robot <|-- HumanOperator
ProductionLineFactory <|-- AutomaticLineFactory
ProductionLineFactory <|-- ManualLineFactory

ProductionReportBuilder <|-- StandardProductionReportBuilder
ProductionTrackingService <|-- LegacyMachineAdapter
Prototype <|-- ProductionOrderTemplate
CommunicationChannel <|-- OPCUAChannel
CommunicationChannel <|-- ModbusChannel
WorkOrder <|-- CNCWorkOrder
WorkOrder <|-- RobotWorkOrder
ReportComponent <|-- BaseProductionReport
ReportComponent <|-- ReportDecorator
ReportDecorator <|-- QualityDecorator
ReportDecorator <|-- TraceabilityDecorator
ReportDecorator <|-- OEEDecorator
ProductionNode <|-- MachineStation
ProductionNode <|-- ProductionGroup

' Core associations
MESController ..> PlannedOrder : creates
MachineFactory ..> Machine : creates
ProductionLineFactory ..> LineMachine : creates
ProductionLineFactory ..> Robot : creates
StandardProductionReportBuilder *-- ProductionReport
ReportDirector o-- ProductionReportBuilder
LegacyMachineAdapter *-- LegacyMachineGateway
MESProductionClient o-- ProductionTrackingService
TemplateRegistry o-- ProductionOrderTemplate
MESProductionPlanner o-- TemplateRegistry
WorkOrder o-- CommunicationChannel
MESScheduler o-- WorkOrder
ReportDecorator o-- ReportComponent
MESShiftCloser o-- ReportComponent
ProductionGroup o-- ProductionNode
MESCapacityService o-- ProductionNode
MESProductionFacade o-- OrderValidator
MESProductionFacade o-- InventoryService
MESProductionFacade o-- MachinePreparationService
MESProductionFacade o-- QualityService
MESProductionFacade o-- TrackingService
MESOperatorConsole o-- MESProductionFacade

' Layout guides to keep the diagram square enough for image export
FunctionalMESProject -[hidden]down-> MESController
MESController -[hidden]right-> MachineFactory
MachineFactory -[hidden]right-> ProductionLineFactory
ProductionLineFactory -[hidden]right-> ReportDirector
ReportDirector -[hidden]down-> MESProductionClient
MESProductionClient -[hidden]right-> MESProductionPlanner
MESProductionPlanner -[hidden]right-> MESScheduler
MESScheduler -[hidden]down-> MESShiftCloser
MESShiftCloser -[hidden]right-> MESCapacityService
MESCapacityService -[hidden]right-> MESProductionFacade

' Functional application wiring
FunctionalMESProject o-- MESController
FunctionalMESProject o-- MESProductionPlanner
FunctionalMESProject o-- MESCapacityService
FunctionalMESProject o-- MESOperatorConsole
FunctionalMESProject o-- MESProductionClient
FunctionalMESProject o-- ReportDirector
FunctionalMESProject o-- MESShiftCloser
FunctionalMESProject ..> ProductionLineFactory : uses
FunctionalMESProject ..> MachineFactory : uses
FunctionalMESProject ..> MESScheduler : creates in _build_dispatcher()
FunctionalMESProject ..> OrderExecutionRequest : processes
FunctionalMESProject ..> PatternImplementation : returns map

@enduml
