@startuml
title MES Functional Order Flow (End-to-End)

actor Operator
participant FunctionalMESProject as APP
participant TemplateRegistry as PROTOTYPE
participant MESProductionFacade as FACADE
participant ProductionLineFactory as AFACTORY
participant MachineFactory as FACTORY
participant MESScheduler as BRIDGE
participant LegacyMachineAdapter as ADAPTER
participant ReportDirector as BUILDER
participant MESShiftCloser as DECORATOR
participant MESController as SINGLETON
participant MESCapacityService as COMPOSITE

Operator -> APP : execute_order(request)
APP -> PROTOTYPE : create(template_key)
PROTOTYPE --> APP : cloned order template
APP -> FACADE : start_order(order,line,planned)
FACADE --> APP : startup ok
APP -> AFACTORY : create_machine(), create_robot()
AFACTORY --> APP : compatible family
APP -> FACTORY : create_machine()
FACTORY --> APP : machine instance
APP -> BRIDGE : release_order(order,line,units)
BRIDGE --> APP : dispatch status
APP -> ADAPTER : report_units(order,line,produced)
ADAPTER --> APP : legacy confirmation
APP -> BUILDER : build report by steps
BUILDER --> APP : ProductionReport
APP -> DECORATOR : enrich report (quality, trace, OEE)
DECORATOR --> APP : enriched report
APP -> SINGLETON : plan/register/close order
APP -> COMPOSITE : calculate_total_units()
COMPOSITE --> APP : plant capacity
APP --> Operator : final result + trace

@enduml
