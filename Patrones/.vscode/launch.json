      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: Demo funcional",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/run_mes_functional_demo.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: Test parcial",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/test/test_PARCIAL.py",
