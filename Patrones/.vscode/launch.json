{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MES: UI proceso completo",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/Test_UI_2ndo_Corte.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: UI por patrones",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/ui_patrones_mes.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: Test parcial",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/test_PARCIAL.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: Test composite",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/test_composite.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: Archivo Python actual",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${fileDirname}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    }
  ]
}
