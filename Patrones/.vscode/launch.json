{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MES: Mini interfaz",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/mini_interfaz_mes.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/src",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "MES: Practica guiada",
      "type": "debugpy",
      "request": "launch",
